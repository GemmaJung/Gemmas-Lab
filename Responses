<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>교직원 강의 피드백</title>
  <style>
    :root {
      --bg1: #e9f0ff; /* 파스텔 톤 */
      --bg2: #ffeef5; /* 파스텔 톤 */
      --bg3: #eafff5; /* 파스텔 톤 */
      --text: #0f172a; /* 다크 네이비 */
      --muted: #475569; /* slate */
      --brand: #111;    /* 버튼/문자 기본 */
      --card: rgba(255,255,255,0.65);
      --card-border: rgba(255,255,255,0.35);
    }
    * { box-sizing: border-box; }
    html, body {
      height: 100%;
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", sans-serif;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .stage {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      display: grid;
      place-items: center;
      background: radial-gradient(1200px 600px at 10% 10%, var(--bg1), transparent 60%),
                  radial-gradient(900px 500px at 90% 20%, var(--bg2), transparent 60%),
                  radial-gradient(1000px 700px at 40% 90%, var(--bg3), transparent 60%),
                  linear-gradient(180deg, #f8fbff, #fdf9ff);
    }
    /* 흐릿한 빛(블러) 애니메이션 */
    .blob {
      position: absolute;
      width: 60vmax; height: 60vmax;
      background: radial-gradient(circle at 30% 30%, #ffffffcc, transparent 60%);
      filter: blur(50px);
      opacity: 0.6;
      animation: float 20s ease-in-out infinite;
      pointer-events: none;
    }
    .blob.b1 { top: -20vmax; left: -10vmax; animation-delay: 0s; }
    .blob.b2 { bottom: -25vmax; right: -15vmax; animation-delay: 5s; }
    .blob.b3 { top: 20vmax; left: 40vmax; animation-delay: 10s; }
    @keyframes float {
      0% { transform: translate3d(0,0,0) scale(1); }
      50% { transform: translate3d(2vw,-2vh,0) scale(1.05); }
      100% { transform: translate3d(0,0,0) scale(1); }
    }

    .card {
      width: min(880px, 92vw);
      background: var(--card);
      border: 1px solid var(--card-border);
      backdrop-filter: saturate(140%) blur(10px);
      border-radius: 24px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      padding: 36px 32px;
    }
    .center { text-align: center; }
    .title {
      font-weight: 700;
      font-size: clamp(36px, 5vw, 64px);
      letter-spacing: -0.02em;
    }
    .subtitle { color: var(--muted); margin-top: 8px; }
    .button {
      margin-top: 24px;
      display: inline-block;
      padding: 14px 22px;
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,0.08);
      background: #fff;
      color: var(--brand);
      font-weight: 600;
      font-size: 16px;
      cursor: pointer;
      transition: transform .06s ease, box-shadow .2s ease;
      box-shadow: 0 6px 14px rgba(0,0,0,0.06);
    }
    .button:hover { transform: translateY(-1px); box-shadow: 0 10px 18px rgba(0,0,0,0.08); }
    .button:active { transform: translateY(0); box-shadow: 0 4px 10px rgba(0,0,0,0.06); }

    /* 폼 레이아웃 */
    form { margin-top: 12px; }
    .q { margin: 18px 0 10px; font-weight: 600; }
    .scale { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .scale label { display: inline-flex; align-items: center; gap: 6px; font-weight: 500; }
    .scale input { width: 18px; height: 18px; }
    textarea, input[type="email"], input[type="text"] {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,0.12);
      background: #fff;
      font-size: 15px;
      resize: vertical;
    }
    textarea { min-height: 96px; }

    .grid { display: grid; gap: 14px; }
    .grid-2 { grid-template-columns: 1fr 1fr; }
    @media (max-width: 720px) { .grid-2 { grid-template-columns: 1fr; } }

    .footer {
      display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 18px;
    }
    .hint { color: var(--muted); font-size: 13px; }
    .submit { padding: 14px 22px; border-radius: 12px; border: none; background: #111; color: #fff; font-weight: 700; cursor: pointer; }
    .submit:disabled { opacity: .6; cursor: wait; }

    /* 뷰 전환 */
    [data-view] { display: none; }
    [data-view].active { display: block; }
  </style>
</head>
<body>
  <main class="stage">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>

    <!-- 메인 화면 -->
    <section id="view-home" class="card center" data-view>
      <div class="title">반갑습니다 <span aria-hidden="true">😊</span></div>
      <p class="subtitle">교직원 대상 강의 피드백 페이지</p>
      <button class="button" id="open-form">강의 만족도 조사</button>
    </section>

    <!-- 설문 폼 화면 -->
    <section id="view-form" class="card" data-view>
      <h2 class="title" style="font-size: clamp(24px,3.5vw,40px);">강의 만족도 조사</h2>

      <form id="feedbackForm">
        <!-- 1.1 -->
        <div class="q">1.1 본 강의 주제는 평소 내가 관심 있는 분야였다.</div>
        <div class="scale" role="radiogroup" aria-label="관심도">
          <label><input type="radio" name="q11" value="1" required> 1</label>
          <label><input type="radio" name="q11" value="2"> 2</label>
          <label><input type="radio" name="q11" value="3"> 3</label>
          <label><input type="radio" name="q11" value="4"> 4</label>
          <label><input type="radio" name="q11" value="5"> 5</label>
        </div>

        <!-- 1.2 -->
        <div class="q">1.2 본 강의는 나에게 필요한 정보를 적절하게 제공하였다.</div>
        <div class="scale" role="radiogroup" aria-label="적절성">
          <label><input type="radio" name="q12" value="1" required> 1</label>
          <label><input type="radio" name="q12" value="2"> 2</label>
          <label><input type="radio" name="q12" value="3"> 3</label>
          <label><input type="radio" name="q12" value="4"> 4</label>
          <label><input type="radio" name="q12" value="5"> 5</label>
        </div>

        <!-- 1.3 -->
        <div class="q">1.3 가장 도움이 되었거나 만족스러웠던 부분</div>
        <textarea name="q13" placeholder="자유 서술"></textarea>

        <!-- 1.4 -->
        <div class="q">1.4 다루지 않았지만 더 궁금한 부분</div>
        <textarea name="q14" placeholder="자유 서술"></textarea>

        <!-- 2. 자유 메시지 -->
        <div class="q">2. 강사에게 하고 싶은 말</div>
        <textarea name="q2" placeholder="자유 서술"></textarea>

        <!-- 3. 이메일 -->
        <div class="q">3. 이메일 (요약본 발송용 / 선택)</div>
        <input type="email" name="email" placeholder="example@school.kr" />

        <div class="footer">
          <div class="hint">제출 시 개인정보는 요약본 발송 및 강의 품질 개선 목적에 한해 사용됩니다.</div>
          <button class="submit" type="submit" id="submitBtn">제출</button>
        </div>
      </form>
    </section>

    <!-- 감사 화면 -->
    <section id="view-thanks" class="card center" data-view>
      <div class="title">감사합니다 <span aria-hidden="true">🎉</span></div>
      <p class="subtitle">소중한 피드백은 강의 품질 개선에 적극 반영됩니다.</p>
    </section>
  </main>

  <script>
    // ▼▼▼ 본인 Apps Script 웹앱 URL로 교체 ▼▼▼
    const GAS_WEB_APP_URL = "https://script.google.com/macros/s/AKfycbwMOmfWS0v-3sTVpNMec2SUHs0GRqztTs6awdPbBZThvAdKNWrz1USB_U872iLSNQEr/exec";

    const views = {
      home: document.getElementById('view-home'),
      form: document.getElementById('view-form'),
      thanks: document.getElementById('view-thanks')
    };
    const openBtn = document.getElementById('open-form');
    const form = document.getElementById('feedbackForm');
    const submitBtn = document.getElementById('submitBtn');

    function show(view) {
      Object.values(views).forEach(v => v.classList.remove('active'));
      views[view].classList.add('active');
    }

    // 초기 뷰
    show('home');

    openBtn.addEventListener('click', () => show('form'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;

      const data = {
        timestamp: new Date().toISOString(),
        q11: form.q11.value,
        q12: form.q12.value,
        q13: form.q13.value?.trim() || "",
        q14: form.q14.value?.trim() || "",
        q2: form.q2.value?.trim() || "",
        email: form.email.value?.trim() || ""
      };

      try {
        // Apps Script CORS 제약을 고려해 no-cors로 전송 (응답 본문은 읽지 않음)
        await fetch(GAS_WEB_APP_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        // 전송 후 바로 감사 화면으로 전환
        show('thanks');
        form.reset();
      } catch (err) {
        alert('제출 중 오류가 발생했습니다. 잠시 후 다시 시도해주세요.');
        console.error(err);
      } finally {
        submitBtn.disabled = false;
      }
    });
  </script>
</body>
</html>
