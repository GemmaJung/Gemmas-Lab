<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>시니어 키오스크 체험</title>

<style>
body{
    margin:0;
    background:#000;
    display:flex;
    justify-content:center;
    font-family:sans-serif;
}

#app{
    width:390px;
    min-height:100vh;
    background:#1c1c1c;
    color:white;
    display:flex;
    flex-direction:column;
    position:relative;
    overflow:hidden;
}

.header{
    background:#ff6b00;
    padding:15px;
    text-align:center;
    font-size:18px;
    font-weight:bold;
}

.content{
    flex:1;
    padding:15px;
    overflow:auto;
}

.footer{
    background:#111;
    padding:10px;
    display:flex;
    justify-content:space-between;
}

button{
    border:none;
    border-radius:8px;
    cursor:pointer;
}

.main-btn{
    width:100%;
    padding:15px;
    margin:10px 0;
    background:#ff6b00;
    color:white;
    font-size:16px;
}

.option-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:8px;
}

.option-btn{
    padding:12px;
    background:#333;
    color:white;
}

.small{ font-size:11px; }
.medium{ font-size:15px; }

.countdown{
    text-align:right;
    font-size:12px;
    color:#ff4444;
}

.tiny-cancel{
    font-size:9px;
    color:#aaa;
}

.popup{
    background:#333;
    padding:20px;
    text-align:center;
    border-radius:12px;
}

/* ===== 시야 흐림 ===== */

.mild-blur {
    filter: blur(0.8px) contrast(95%) saturate(90%);
}

.strong-blur {
    filter: blur(2px) contrast(80%) saturate(75%);
}

.vignette::after {
    content:"";
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    pointer-events:none;
    background: radial-gradient(circle, transparent 60%, rgba(0,0,0,0.6) 100%);
}

.shake {
    animation: shake 0.15s infinite;
}

@keyframes shake {
    0% { transform: translate(0px, 0px); }
    25% { transform: translate(0.5px, -0.5px); }
    50% { transform: translate(-0.5px, 0.5px); }
    75% { transform: translate(0.5px, 0.5px); }
    100% { transform: translate(0px, 0px); }
}

</style>
</head>
<body>

<div id="app">

<div class="header">KIOSK ORDER</div>
<div class="content" id="screen"></div>

<div class="footer">
<button onclick="goBack()">◀ 이전</button>
<button onclick="goHome()">홈</button>
</div>

</div>

<script>

let difficulty = 1;
let step = 0;
let startTime;
let clicks = 0;
let timer;
let timeLeft = 25;

function init(){
    document.getElementById("screen").innerHTML=`
        <h2>시니어의 눈으로 경험해보세요</h2>
        <button class="main-btn" onclick="chooseDifficulty(1)">1단계 체험</button>
        <button class="main-btn" onclick="chooseDifficulty(2)">2단계 체험</button>
    `;
}
init();

function chooseDifficulty(level){
    difficulty = level;
    step = 1;
    clicks = 0;
    startTime = new Date();
    timeLeft = 25;

    const app = document.getElementById("app");
    app.classList.remove("mild-blur","strong-blur","vignette","shake");

    if(level==1){
        app.classList.add("mild-blur");
    }

    if(level==2){
        app.classList.add("strong-blur","vignette","shake");
        startTimer();
    }

    render();
}

function startTimer(){
    timer = setInterval(()=>{
        timeLeft--;
        if(timeLeft<=0){
            clearInterval(timer);
            showReport(true);
        }
        document.getElementById("count")?.innerText="남은 시간: "+timeLeft+"초";
    },1000);
}

function render(){
    let fontClass = difficulty==1?"medium":"small";
    let many = difficulty==1?8:24;
    let english = difficulty==2;

    if(step==1){
        let options="";
        for(let i=1;i<=many;i++){
            options+=`<button class="option-btn ${fontClass}" onclick="nextStep()">메뉴 ${i}</button>`;
        }

        document.getElementById("screen").innerHTML=`
            ${difficulty==2?'<div id="count" class="countdown"></div>':''}
            <h3 class="${fontClass}">${english?"Select Menu":"메뉴 선택"}</h3>
            <div class="option-grid">${options}</div>
        `;
    }

    else if(step==2){
        document.getElementById("screen").innerHTML=`
            <h3 class="${fontClass}">${english?"Choose Size":"사이즈 선택"}</h3>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Small</button>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Medium</button>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Large</button>
        `;
    }

    else if(step==3 && difficulty==2){
        document.getElementById("screen").innerHTML=`
            <div class="popup">
                <p>🔥 LIMITED EVENT! Add Combo?</p>
                <button class="main-btn small" onclick="nextStep()">YES</button>
                <button class="tiny-cancel" onclick="nextStep()">No Thanks</button>
            </div>
        `;
    }

    else if(step==3 || step==4){
        document.getElementById("screen").innerHTML=`
            <h3 class="${fontClass}">${english?"Dine In or Take Out":"매장 / 포장 선택"}</h3>
            <button class="main-btn ${fontClass}" onclick="nextStep()">${english?"Dine In":"매장"}</button>
            <button class="main-btn ${fontClass}" onclick="nextStep()">${english?"Take Out":"포장"}</button>
        `;
    }

    else if(step==5){
        document.getElementById("screen").innerHTML=`
            <h3 class="${fontClass}">${english?"Select Payment":"결제 방법 선택"}</h3>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Credit Card</button>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Mobile Pay</button>
            <button class="main-btn ${fontClass}" onclick="nextStep()">Cash</button>
        `;
    }

    else{
        showReport(false);
    }
}

function nextStep(){
    clicks++;
    step++;
    render();
}

function showReport(timeout){
    clearInterval(timer);
    let duration = Math.floor((new Date()-startTime)/1000);

    document.getElementById("screen").innerHTML=`
        <h2>체험 결과</h2>
        <p>소요 시간: ${duration}초</p>
        <p>클릭 횟수: ${clicks}</p>
        ${timeout?"<p style='color:red'>시간 초과로 종료되었습니다.</p>":""}
        <hr>
        <p>
        이 경험이 불편했다면,<br>
        어르신들은 매번 이런 환경에 놓입니다.<br><br>
        시니어 키오스크 교육은 선택이 아닌 필수입니다.
        </p>
        <button class="main-btn" onclick="location.reload()">다시 체험</button>
    `;
}

function goBack(){
    if(step>1){ step--; render(); }
}

function goHome(){
    location.reload();
}

</script>

</body>
</html>
